@page "/"

<PageTitle>Home</PageTitle>

<div class="container py-4" style="max-width: 1400px;">
    <!-- ===== 第1行：3列 ===== -->
    <div class="row mb-3 gy-3">
        <div class="col-12 col-md-4">
            <div class="p-3 border rounded">Div 1</div>
        </div>
        <div class="col-12 col-md-4">
            <div class="p-3 border rounded">Div 2</div>
        </div>
        <div class="col-12 col-md-4">
            <div class="p-3 border rounded">Div 3</div>
        </div>
    </div>

    <!-- ===== 第2行：左1列 + 右2行 ===== -->
    <div class="row mb-3 gy-3">
        <div class="col-12 col-md-6">
            <div class="card h-100">
                <div class="card-header">Table</div>
                <div class="card-body">
                    <table class="table table-bordered mb-0">
                        <thead>
                            <tr><th>#</th><th>Value</th></tr>
                        </thead>
                        <tbody>
                            <tr><td>1</td><td></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-md-6 d-flex flex-column gap-3">
            <div class="card">
                <div class="card-body d-flex gap-2">
                    <select class="form-select">
                        <option>请选择...</option>
                    </select>
                    <button class="btn btn-primary">Load</button>
                </div>
            </div>
            <div class="card flex-grow-1">
                <div class="card-body d-flex align-items-center justify-content-center text-muted"
                     style="min-height: 300px;">
                    <span>SVG Area</span>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== 第3行：2列 ===== -->
    <div class="row gy-3">
        <div class="col-12 col-md-6">
            <div class="p-3 border rounded text-muted">备用</div>
        </div>
        <div class="col-12 col-md-6">
            <div class="card">
                <div class="card-header">Image Stream</div>
                <div class="card-body d-flex align-items-center justify-content-center text-muted"
                     style="min-height: 200px;">
                    <span>Stream Area</span>
                </div>
            </div>
        </div>
    </div>
</div>